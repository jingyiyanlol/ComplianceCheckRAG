{
  "title": "App Performance",
  "uid": "ccrag-app-perf",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "rate(ccrag_query_total[5m])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "End-to-End Latency p50/p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(ccrag_query_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(ccrag_query_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Retrieval Latency p50/p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(ccrag_retrieval_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(ccrag_retrieval_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "title": "LLM Latency p50/p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(ccrag_llm_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(ccrag_llm_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "title": "Chunks Retrieved (avg)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "rate(ccrag_chunks_retrieved_sum[5m]) / rate(ccrag_chunks_retrieved_count[5m])",
          "legendFormat": "avg chunks"
        }
      ]
    },
    {
      "id": 6,
      "title": "PII Hits by Entity Type",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "rate(ccrag_pii_hits_total[5m])",
          "legendFormat": "{{entity_type}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(ccrag_query_total{status='error'}[5m])",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "id": 8,
      "title": "Feedback (thumbs up vs down)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(ccrag_feedback_total[5m])",
          "legendFormat": "{{rating}}"
        }
      ]
    }
  ]
}
