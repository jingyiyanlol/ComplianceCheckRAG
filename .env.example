# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma3:4b-q4_0
EMBED_MODEL=nomic-embed-text

# ChromaDB
# "local" uses PersistentClient (no Docker needed); "http" connects to a running server
CHROMA_MODE=local
CHROMA_LOCAL_PATH=.chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_AUTH_TOKEN=
CHROMA_COLLECTION=compliance_docs

# Telemetry
TELEMETRY_DB_PATH=telemetry.db

# App
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:5173
